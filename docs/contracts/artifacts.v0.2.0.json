      "versionField": "schemaVersion",
      "trustBundleSchema": "forge-recorder-custody-trust-bundle/1.0.0",
      "authorizationSchema": "forge-recorder-custody-authorization/1.0.0",
      "proofSchema": "forge-recorder-custody-proof/1.0.0",
      "versionRule": "the hash-pinned purpose-limited Ed25519 public trust bundle, at-most-eight-hour exact acceptance authorization and authorization-byte digest, native two-port start/stop D55 identity/UID/descriptor/response-transcript continuity, canonical receipt binding, separate create-new proof, and permanent device/recorded-device/field/sharing/training nonclaims are major-version semantics"
    },
