<?xml version="1.0"?>
<robot name="fixture_rover">
  <link name="base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.32 0.22 0.08"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.32 0.22 0.08"/></geometry>
    </collision>
  </link>
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.028"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.028"/></geometry>
    </collision>
  </link>
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.028"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.028"/></geometry>
    </collision>
  </link>
  <joint name="left_wheel_joint" type="revolute">
    <parent link="base"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.12 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="20.0"/>
  </joint>
  <joint name="right_wheel_joint" type="revolute">
    <parent link="base"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.12 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="20.0"/>
  </joint>
</robot>
