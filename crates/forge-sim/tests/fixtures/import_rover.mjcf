<mujoco model="fixture_mjcf_rover">
  <option gravity="0 0 -9.80665" density="1.225"/>
  <worldbody>
    <body name="base" pos="0 0 0">
      <geom type="box" size="0.16 0.11 0.04" pos="0 0 0"/>
      <body name="left_wheel" pos="0 0.12 -0.02">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0" range="-3.14159 3.14159"/>
        <geom type="cylinder" size="0.04 0.014" pos="0 0 0"/>
      </body>
      <body name="right_wheel" pos="0 -0.12 -0.02">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0" range="-3.14159 3.14159"/>
        <geom type="cylinder" size="0.04 0.014" pos="0 0 0"/>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor name="left_wheel_motor" joint="left_wheel_joint" gear="1"/>
    <motor name="right_wheel_motor" joint="right_wheel_joint" gear="1"/>
  </actuator>
</mujoco>
