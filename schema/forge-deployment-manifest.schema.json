{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgedttc.dev/schemas/forge-deployment-manifest.v1.json",
  "title": "ForgedTTC deployment manifest",
  "description": "Versioned, non-secret deployment and promotion authority. A valid manifest is contract evidence only until its referenced gates and environment are independently verified.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deploymentId",
    "environment",
    "status",
    "source",
    "artifacts",
    "configuration",
    "ownership",
    "evidence",
    "promotion",
    "authority"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "maxLength": 300
    },
    "schemaVersion": {
      "const": "forge-deployment-manifest/1.0.0"
    },
    "deploymentId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,62}$"
    },
    "environment": {
      "enum": [
        "local",
        "ci",
        "sandbox",
        "staging",
        "production",
        "controlled-lab"
      ]
    },
    "status": {
      "enum": [
        "planned",
        "active",
        "retired"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "treeHash",
        "protectedMain",
        "worktreeClean",
        "builtAt"
      ],
      "properties": {
        "repository": {
          "const": "RNT56/TTC"
        },
        "revision": {
          "$ref": "#/$defs/gitHash"
        },
        "treeHash": {
          "$ref": "#/$defs/gitHash"
        },
        "protectedMain": {
          "type": "boolean"
        },
        "worktreeClean": {
          "type": "boolean"
        },
        "builtAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabledCapabilities",
        "values",
        "secretRefs"
      ],
      "properties": {
        "enabledCapabilities": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 16,
          "items": {
            "enum": [
              "github-oauth",
              "anthropic-etl",
              "modal-gpu",
              "photoscan-command",
              "colmap-command",
              "occt-command",
              "vendor-refresh",
              "print-quote",
              "controlled-lab"
            ]
          }
        },
        "values": {
          "$ref": "#/$defs/stringMap"
        },
        "secretRefs": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "ownership": {
      "$ref": "#/$defs/stringMap"
    },
    "evidence": {
      "type": "array",
      "maxItems": 48,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceEnvironment",
        "sourceManifestSha256",
        "sourceEvidenceSha256",
        "rollbackPlanSha256",
        "databasePlanSha256",
        "promotedAt",
        "signoffs"
      ],
      "properties": {
        "sourceEnvironment": {
          "enum": [
            "protected-main",
            "sandbox",
            "staging"
          ]
        },
        "sourceManifestSha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "sourceEvidenceSha256": {
          "$ref": "#/$defs/sha256"
        },
        "rollbackPlanSha256": {
          "$ref": "#/$defs/sha256"
        },
        "databasePlanSha256": {
          "$ref": "#/$defs/sha256"
        },
        "promotedAt": {
          "type": "string",
          "format": "date-time"
        },
        "signoffs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "role",
              "owner",
              "signedAt",
              "evidenceSha256"
            ],
            "properties": {
              "role": {
                "type": "string",
                "minLength": 3,
                "maxLength": 80
              },
              "owner": {
                "type": "string",
                "minLength": 3,
                "maxLength": 160
              },
              "signedAt": {
                "type": "string",
                "format": "date-time"
              },
              "evidenceSha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publicTraffic",
        "realUserData",
        "providerCredentials",
        "hardware",
        "externalBeta",
        "live",
        "field"
      ],
      "properties": {
        "publicTraffic": {
          "type": "boolean"
        },
        "realUserData": {
          "type": "boolean"
        },
        "providerCredentials": {
          "type": "boolean"
        },
        "hardware": {
          "type": "boolean"
        },
        "externalBeta": {
          "type": "boolean"
        },
        "live": {
          "type": "boolean"
        },
        "field": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "gitHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stringMap": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9_]{1,79}$"
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      },
      "maxProperties": 160
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component",
        "uri",
        "sha256",
        "sbomSha256",
        "provenanceSha256"
      ],
      "properties": {
        "component": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "uri": {
          "type": "string",
          "minLength": 8,
          "maxLength": 500
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sbomSha256": {
          "$ref": "#/$defs/sha256"
        },
        "provenanceSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "uri",
        "sha256"
      ],
      "properties": {
        "gate": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100
        },
        "uri": {
          "type": "string",
          "minLength": 8,
          "maxLength": 500
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
