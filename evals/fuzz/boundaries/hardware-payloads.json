{
  "version": "forge-boundary-fuzz.v1",
  "surface": "hardware-payloads",
  "description": "Fail-closed command, telemetry, and supervisor payloads for the fixture hardware bridge; no physical hardware is exercised.",
  "cases": [
    {"id": "hardware-config-valid", "focus": "The reviewed D12 Betaflight failsafe diff retains physical confirmation.", "input": {"operation": "config-diff", "payload": {"firmware": "betaflight", "mixer": "quadx", "rates": {"failsafe_delay": 10}}}, "expect": {"outcome": "accept"}},
    {"id": "hardware-config-unreviewed-mixer", "focus": "The v1 artifact cannot expand to an unreviewed mixer.", "input": {"operation": "config-diff", "payload": {"firmware": "betaflight", "mixer": "quadx\nsave", "rates": {"failsafe_delay": 10}}}, "expect": {"outcome": "reject", "contains": "D12 quadx mixer"}},
    {"id": "hardware-config-unreviewed-key", "focus": "The v1 artifact cannot expand to an unreviewed Betaflight setting.", "input": {"operation": "config-diff", "payload": {"firmware": "betaflight", "mixer": "quadx", "rates": {"airmode": "ON"}}}, "expect": {"outcome": "reject", "contains": "exactly the reviewed failsafe_delay"}},
    {"id": "hardware-config-unsafe-low-delay", "focus": "Failsafe delay below the reviewed safety floor fails closed.", "input": {"operation": "config-diff", "payload": {"firmware": "betaflight", "mixer": "quadx", "rates": {"failsafe_delay": 1}}}, "expect": {"outcome": "reject", "contains": "2 through 200 deciseconds"}},
    {"id": "hardware-telemetry-unsorted-valid", "focus": "Finite unique capture samples normalize to timestamp order.", "input": {"operation": "telemetry", "payload": {"samples": [{"t": 1, "x": 1}, {"t": 0, "x": 0}]}}, "expect": {"outcome": "accept", "frameCount": 2}},
    {"id": "hardware-telemetry-duplicate-time", "focus": "Duplicate hardware timestamps are ambiguous and rejected.", "input": {"operation": "telemetry", "payload": {"samples": [{"t": 0}, {"t": 0}]}}, "expect": {"outcome": "reject", "contains": "unique and strictly increasing"}},
    {"id": "hardware-telemetry-nan-time", "focus": "NaN capture time cannot enter a replay tape.", "input": {"operation": "telemetry", "payload": {"samples": [{"t": {"$number": "nan"}}]}}, "expect": {"outcome": "reject", "contains": "bounded JSON"}},
    {"id": "hardware-telemetry-nan-state", "focus": "Non-finite nested telemetry is rejected before stable hashing.", "input": {"operation": "telemetry", "payload": {"samples": [{"t": 0, "voltageV": {"$number": "nan"}}]}}, "expect": {"outcome": "reject", "contains": "bounded JSON"}},
    {"id": "hardware-supervisor-valid", "focus": "Finite in-envelope state remains advisory.", "input": {"operation": "supervisor", "payload": {"config": {"geofenceRadiusM": 5}, "state": {"positionM": [1, 0, 1]} }}, "expect": {"outcome": "accept", "allowPolicy": true}},
    {"id": "hardware-supervisor-geofence-hold", "focus": "A finite geofence violation produces a supervisor hold.", "input": {"operation": "supervisor", "payload": {"config": {"geofenceRadiusM": 5}, "state": {"positionM": [6, 0, 0]} }}, "expect": {"outcome": "accept", "allowPolicy": false}},
    {"id": "hardware-supervisor-short-vector", "focus": "Malformed state vectors fail closed instead of defaulting to safety.", "input": {"operation": "supervisor", "payload": {"config": {}, "state": {"positionM": [1, 2]} }}, "expect": {"outcome": "reject", "contains": "finite 3-vector"}},
    {"id": "hardware-supervisor-nan-limit", "focus": "NaN safety configuration cannot bypass comparisons.", "input": {"operation": "supervisor", "payload": {"config": {"maxAttitudeRad": {"$number": "nan"}}, "state": {}}}, "expect": {"outcome": "reject", "contains": "bounded JSON"}},
    {"id": "hardware-supervisor-negative-geofence", "focus": "Supervisor safety bounds must be physically positive.", "input": {"operation": "supervisor", "payload": {"config": {"geofenceRadiusM": -1}, "state": {}}}, "expect": {"outcome": "reject", "contains": "greater than"}},
    {"id": "hardware-supervisor-string-kill-switch", "focus": "Kill-switch authority is a strict boolean, not truthy input.", "input": {"operation": "supervisor", "payload": {"config": {}, "state": {"killSwitch": "false"}}}, "expect": {"outcome": "reject", "contains": "boolean"}}
  ]
}
