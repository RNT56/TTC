# ForgedTTC — editor baseline (PRE-004). Formatters own the details
# (rustfmt, the TS toolchain); this file keeps editors from fighting them.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[*.md]
# trailing double-space is meaningful markdown
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
