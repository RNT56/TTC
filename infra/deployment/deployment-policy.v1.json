  "secrets": {
    "referencePattern": "^secret://[a-z0-9][a-z0-9./_-]{2,160}@[A-Za-z0-9._-]{1,80}$",
    "classes": {
      "auth-signing": {
        "maximumAgeDays": 90,
        "overlapRequired": false,
        "rotationEffect": "existing sessions may be invalidated"
      },
      "database": {
        "maximumAgeDays": 90,
        "overlapRequired": true,
        "rotationEffect": "dual credential or ordered pool drain"
      },
      "object-storage": {
        "maximumAgeDays": 90,
        "overlapRequired": true,
        "rotationEffect": "dual key then old-key revocation"
      },
      "oauth": {
        "maximumAgeDays": 180,
        "overlapRequired": true,
        "rotationEffect": "provider overlap where supported"
      },
      "provider": {
        "maximumAgeDays": 90,
        "overlapRequired": true,
        "rotationEffect": "sandbox validation then environment-specific cutover"
      },
      "review-authority": {
        "maximumAgeDays": 90,
        "overlapRequired": false,
        "rotationEffect": "review sessions invalidated"
      },
      "desktop-signing": {
        "maximumAgeDays": 365,
        "overlapRequired": true,
        "rotationEffect": "old and new signed artifacts remain independently verifiable"
      }
    },
    "emergencyRevocationHours": 4,
    "rules": [
      "secret values never enter manifests, logs, evidence, source, generated docs, or promotion records",
      "every managed secret reference is environment-specific and versioned",
      "rotation proves new credential use before old credential revocation",
      "suspected disclosure triggers immediate revocation rather than waiting for maximum age"
    ]
  }
}
