      "managed": true,
      "credentials": "staging-only",
      "data": "synthetic-or-sanitized",
      "requiredComponents": [
        "studio-static",
        "gateway",
        "validator",
        "workers",
        "postgres",
        "object-storage"
      ],
      "requiredGates": [
        "protected-main",
