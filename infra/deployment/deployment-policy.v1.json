{
  "schemaVersion": "forge-deployment-policy/1.0.0",
  "manifestVersion": "1.0.0",
  "manifestSchema": "schema/forge-deployment-manifest.schema.json",
  "decision": "D68",
  "maturity": "contract",
  "currentRuntimeClaim": "local-prod-like-only",
  "topology": {
    "firstOperatingShape": "single-region-small",
    "components": [
      "studio-static",
      "gateway",
      "validator",
      "workers",
      "postgres",
      "object-storage",
      "gpu-provider",
      "desktop",
      "controlled-lab"
    ],
    "stateAuthorities": {
      "postgres": "relational truth, ownership, jobs, consent, lifecycle, audit, and immutable revision metadata",
      "object-storage": "private checksum-bound payload bytes; never independent admission authority",
      "gateway": "authenticated mutation, cross-store transactions, admission, and lifecycle orchestration",
      "workers": "lease-fenced compute; results gain authority only through gateway/Postgres materialization",
      "validator": "sovereign model, export, replay, recorder, and co-design admission",
      "desktop": "local filesystem and serial custody under explicit D30/D12 gates"
    },
    "forbiddenWithoutDecision": [
      "multi-region active-active",
      "Kubernetes",
      "production worker public ingress",
      "direct browser access to Postgres or object credentials",
      "automatic hardware arming or authority promotion"
    ]
  },
  "environments": {
    "local": {
      "kind": "development",
      "managed": false,
      "credentials": "development-only",
      "data": "fixture-or-owner-local",
      "requiredComponents": [],
      "requiredGates": [],
      "requiredOwnershipRoles": [],
      "maximumAuthority": {
        "publicTraffic": false,
        "realUserData": false,
        "providerCredentials": false,
        "hardware": false,
        "externalBeta": false,
        "live": false,
        "field": false
      }
    },
