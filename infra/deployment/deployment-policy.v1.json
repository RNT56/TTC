        "releaseMaintainer",
        "platformOperator",
        "securityOwner",
        "dataOwner",
        "incidentCommander",
        "supportOwner"
      ],
      "maximumAuthority": {
        "publicTraffic": true,
        "realUserData": true,
        "providerCredentials": true,
        "hardware": false,
        "externalBeta": true,
        "live": true,
        "field": false
      }
    },
    "controlled-lab": {
      "kind": "named-hardware-lab",
      "managed": true,
      "credentials": "lab-and-signing-only",
      "data": "explicitly-consented-lab-evidence",
      "requiredComponents": [
        "validator",
        "desktop",
        "controlled-lab"
      ],
      "requiredGates": [
        "protected-main",
        "ci",
        "security",
        "deployment-policy",
        "signed-desktop",
        "D30",
        "D12",
        "lab-supervisor",
        "physical-confirmation"
      ],
      "requiredOwnershipRoles": [
        "releaseMaintainer",
        "securityOwner",
        "labSupervisor",
        "evidenceReviewer"
      ],
      "maximumAuthority": {
        "publicTraffic": false,
        "realUserData": false,
        "providerCredentials": false,
        "hardware": true,
        "externalBeta": false,
        "live": false,
        "field": false
      }
    }
  },
  "promotion": {
    "edges": [
      {
        "from": "protected-main",
        "to": "sandbox"
      },
      {
        "from": "sandbox",
        "to": "staging"
      },
      {
        "from": "staging",
        "to": "production"
      },
      {
        "from": "protected-main",
        "to": "controlled-lab"
      }
    ],
    "artifactRule": "build once from clean protected main; promote identical component digests without rebuilding",
    "databaseRule": "apply forward migrations in each environment; never copy production data down except an independently authorized sanitized export",
    "secretRule": "resolve environment-specific versioned secret references at deployment; never copy secret values or references across environments",
    "rollbackRule": "retain an artifact rollback target and application rollback procedure; database history remains forward-only"
  },
  "ownership": {
    "roles": [
      "releaseMaintainer",
      "platformOperator",
      "securityOwner",
      "dataOwner",
      "incidentCommander",
      "supportOwner",
      "labSupervisor",
      "evidenceReviewer"
    ],
    "rule": "every required role resolves to a named accountable owner or rotation; an empty, TBD, team-only, or repository-bot value is invalid"
  },
