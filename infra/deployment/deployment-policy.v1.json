    "production": {
      "kind": "public-service",
      "managed": true,
      "credentials": "production-only",
      "data": "real-user-data",
      "requiredComponents": [
        "studio-static",
        "gateway",
        "validator",
        "workers",
        "postgres",
        "object-storage"
      ],
      "requiredGates": [
        "protected-main",
        "ci",
        "security",
