{
  "name": "@forge/gateway",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "FORGE gateway - thin Fastify API; spawns the forge-validate binary (process isolation + bit-equality with CI, D17).",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "test:object-storage": "node scripts/object-delete-smoke.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@auth/pg-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@fastify/rate-limit": "^11.1.0",
    "@sinclair/typebox": "^0.34.0",
    "fastify": "^5.0.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "SEE LICENSE IN ../../LICENSE"
}
