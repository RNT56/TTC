{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FORGE Desktop",
  "version": "0.1.0",
  "identifier": "app.forge.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../studio dev --host 127.0.0.1",
    "beforeBuildCommand": "pnpm --dir ../studio build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../studio/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FORGE Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage", "deb"],
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "FORGE bridge and field recorder shell"
  }
}
